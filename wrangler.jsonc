{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sick",
  "main": "worker.js",
  "compatibility_date": "2026-07-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    // Worker handles short install paths before static 404.
    "run_worker_first": [
      "/sick",
      "/sick/",
      "/nets",
      "/nets/",
      "/nets.sh"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
